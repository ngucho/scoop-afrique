# Database — pooler URL (Supabase Connect dialog → PostgreSQL → URI)
# Single variable for all DB access via Drizzle ORM (parameterized queries, SQL injection safe)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Storage — service role key for Supabase Storage (images, PDFs)
# Project URL is derived from DATABASE_URL; no SUPABASE_URL needed
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ImgBB — optional; large images compressed in admin (≤3 Mo) then uploaded via API
# https://api.imgbb.com/
# IMGBB_API_KEY=

# Auth0 — JWT validation is local (decode + iss/aud/exp). No backend call to Auth0 for token check.
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_AUDIENCE="https://api.scoop-afrique.com"
# Reader Auth0 SPA client id (JWT azp) — staff APIs reject this; reader APIs require it
# AUTH0_READER_CLIENT_ID=

# Canonical site URL for digest links (optional; defaults to scoop-afrique.com)
# PUBLIC_SITE_URL=https://www.scoop-afrique.com

# Digest cron (POST /api/v1/digest/run with header x-digest-cron-secret)
# DIGEST_CRON_SECRET=

# Resend webhook (Svix signing secret from Resend dashboard)
# RESEND_WEBHOOK_SECRET=whsec_...

# Auth0 Management API (only when backend updates user metadata or password)
# AUTH0_MANAGEMENT_CLIENT_ID=...
# AUTH0_MANAGEMENT_CLIENT_SECRET=...

# Server
PORT=4000
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001

# API prefix
API_PREFIX=/api/v1

# Notifications — email (Resend) + WhatsApp/SMS (Twilio)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# NOTIFICATION_EMAIL=contact@scoop-afrique.com,autre@email.com
# Twilio — WhatsApp + SMS (devis requests, send devis/invoice)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=+2250700000000
# TWILIO_SMS_TO=+2250700000000
