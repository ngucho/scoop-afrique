{
  "name": "@scoop-afrique/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @scoop-afrique/api-logger run build",
    "build": "tsc && node scripts/copy-pdf-templates.js",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:bootstrap": "tsx scripts/bootstrap-drizzle-migrations.ts"
  },
  "dependencies": {
    "@scoop-afrique/api-logger": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.6.0",
    "jose": "^5.9.6",
    "postgres": "^3.4.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
