# Auth0 v4 (required for CRM login)
# Callback URL: http://localhost:3002/auth/callback
AUTH0_SECRET="<generate: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\">"
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
APP_BASE_URL="http://localhost:3002"
# API audience so the access token is valid for your backend
AUTH0_AUDIENCE="https://api.scoop-afrique.com"

# Backend API URL
NEXT_PUBLIC_API_URL="http://localhost:4000"
