# Auth0 v4 (required for backoffice login)
# See docs/AUTH0_SETUP.md. Callback URL: http://localhost:3001/auth/callback
AUTH0_SECRET="<generate: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\">"
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
APP_BASE_URL="http://localhost:3001"
# API audience so the access token is valid for your backend
AUTH0_AUDIENCE="https://api.scoop-afrique.com"

# Reader accounts (separate Auth0 SPA — callback http://localhost:3001/reader/auth/callback)
READER_AUTH0_CLIENT_ID=""
READER_AUTH0_CLIENT_SECRET=""
# Optional: separate cookie encryption secret (defaults to AUTH0_SECRET)
# READER_AUTH0_SECRET=""

# Existing
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Reader site URL (canonicals, sitemap, OG). Production: https://www.scoop-afrique.com
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
# Optional: explicit reader URL for cross-links from apps/brands (defaults to https://www.scoop-afrique.com)
# NEXT_PUBLIC_READER_SITE_URL="http://localhost:3001"